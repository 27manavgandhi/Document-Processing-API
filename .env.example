NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/document_processing

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

CORS_ORIGIN=*
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

LOG_LEVEL=debug

MAX_FILE_SIZE_MB=10
ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,text/plain,application/msword

QUEUE_CONCURRENCY=5
JOB_TIMEOUT_MS=120000
JOB_MAX_ATTEMPTS=3

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_MAX_ATTEMPTS=3

PROCESSING_MIN_DELAY_MS=10000
PROCESSING_MAX_DELAY_MS=20000